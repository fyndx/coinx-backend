{
  "name": "coinx-backend",
  "version": "1.0.0",
  "description": "CoinX Backend - Sync server for the CoinX expense tracker",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "lint": "bunx biome lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.0",
    "@logtail/pino": "^0.5.8",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sentry/bun": "^10.42.0",
    "@supabase/supabase-js": "^2.93.1",
    "dotenv": "^17.2.3",
    "elysia": "^1.3.0",
    "jose": "^6.1.3",
    "pg": "^8.17.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@sentry/types": "^10.42.0",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.16.0",
    "bun-types": "^1.3.6",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}