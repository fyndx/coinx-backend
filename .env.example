# Server
PORT=3000
NODE_ENV=development

# Database (Supabase Postgres)
DATABASE_URL="postgresql://user:password@pooler-host:5432/postgres"
# Direct connection (bypasses pooler — required for migrations)
DIRECT_URL="postgresql://user:password@db-host:5432/postgres"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# Better Stack (Observability)
SENTRY_DSN="https://your-key@s2282467.eu-fsn-3.betterstackdata.com/2282467"
BETTERSTACK_SOURCE_TOKEN="your-source-token"
