generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id              String          @id @default(uuid())
  transactionTime DateTime        @map("transaction_time")
  amount          Decimal         @db.Decimal(10, 2)
  note            String?
  transactionType TransactionType @map("transaction_type")
  categoryId      String          @map("category_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime?       @updatedAt @map("updated_at")
  category        Category        @relation(fields: [categoryId], references: [id])

  @@map("coinx_transaction")
}

model Category {
  id           String          @id @default(uuid())
  name         String          @unique
  icon         String          @unique
  color        String          @unique
  type         TransactionType
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime?       @updatedAt @map("updated_at")
  transactions Transaction[]

  @@map("coinx_category")
}

model Product {
  id                     String                  @id @default(uuid())
  name                   String
  image                  String?
  notes                  String?
  defaultUnitCategory    String                  @map("default_unit_category")
  createdAt              DateTime                @default(now()) @map("created_at")
  productListings        ProductListing[]
  productListingsHistory ProductListingHistory[]

  @@map("coinx_product")
}

model Store {
  id              String           @id @default(uuid())
  name            String           @unique
  location        String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime?        @updatedAt @map("updated_at")
  productListings ProductListing[]

  @@unique([name, location], name: "unique_store_name_location")
  @@map("coinx_store")
}

model ProductListing {
  id        String                  @id @default(uuid())
  productId String                  @map("product_id")
  name      String
  storeId   String                  @map("store_id")
  url       String?
  price     Decimal
  quantity  Float
  unit      String
  createdAt DateTime                @default(now()) @map("created_at")
  updatedAt DateTime?               @updatedAt @map("updated_at")
  product   Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  history   ProductListingHistory[]

  @@index([productId])
  @@index([storeId])
  @@map("coinx_product_listing")
}

model ProductListingHistory {
  id               String         @id @default(uuid())
  productId        String         @map("product_id")
  productListingId String         @map("product_listing_id")
  price            Decimal
  recordedAt       DateTime       @default(now()) @map("recorded_at")
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productListing   ProductListing @relation(fields: [productListingId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productListingId])
  @@index([recordedAt])
  @@map("coinx_product_listing_history")
}

enum TransactionType {
  Income
  Expense
}
